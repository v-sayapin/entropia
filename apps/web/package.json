{
  "name": "entropia",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.server.json src/server/app/index.ts",
    "build": "yarn clean && tsx tools/build.ts",
    "build:server": "NODE_ENV=production rolldown -c",
    "build:ssr": "NODE_ENV=production vite build --ssr",
    "build:client": "NODE_ENV=production vite build",
    "start": "NODE_ENV=production node dist/server/index.js",
    "clean": "rm -rf dist",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@fastify/middie": "^9.3.2",
    "@types/connect": "^3.4.38",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.46.0",
    "rolldown": "^1.0.0-rc.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-solid": "^2.11.12"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "yarn@4.14.1"
}
