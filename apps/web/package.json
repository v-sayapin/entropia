{
  "name": "entropia",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.server.json src/server/app/index.ts",
    "build": "yarn clean && tsx tools/build.ts",
    "build:server": "NODE_ENV=production rolldown -c",
    "build:ssr": "NODE_ENV=production vite build --ssr",
    "build:client": "NODE_ENV=production vite build",
    "start": "NODE_ENV=production node dist/server/index.js",
    "clean": "rm -rf dist",
    "ts-check": "tsc --build --noEmit",
    "lint": "oxlint --fix",
    "lint-check": "oxlint",
    "fmt": "oxfmt",
    "fmt-check": "oxfmt --check"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@fastify/middie": "^9.3.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-plugin-solid": "^0.14.5",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "rolldown": "^1.0.0-rc.12",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-solid": "^2.11.11"
  },
  "dependenciesMeta": {
    "eslint-plugin-solid@0.14.5": {
      "unplugged": true
    }
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "yarn@4.13.0"
}
