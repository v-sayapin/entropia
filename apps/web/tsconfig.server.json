{
	"extends": "./tsconfig.base.json",
	"include": ["src/server", "src/shared"],
	"compilerOptions": {
		"paths": {
			"src/server/*": ["./src/server/*/index.ts", "./src/server/*"],
			"src/shared/*": ["./src/shared/*/index.ts", "./src/shared/*"]
		},

		"composite": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
	}
}
